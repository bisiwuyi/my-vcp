{
  "name": "OpenCodeArchitect",
  "displayName": "OpenCode 系统进化桥接器",
  "description": "VCP 2.0 自我进化回路 - Ritsu 与 OpenCode 的协作桥梁。所有操作通过自然语言 chat 对话完成，支持多 Agent 多话题管理。",
  "version": "2.2.0",
  "pluginType": "synchronous",
  "entryPoint": {
    "command": "node index.js"
  },
  "capabilities": ["autonomous_coding", "system_analysis", "multi_topic"],
  "invocationCommands": [
    {
      "command": "chat",
      "description": "对话模式 - 与 OpenCode LLM 持续对话。支持多 Agent 多话题，每个话题独立的 OpenCode 会话",
      "parameters": {
        "message": {
          "type": "string",
          "required": true,
          "description": "发送给 OpenCode 的消息"
        },
        "agentId": {
          "type": "string",
          "default": "default",
          "description": "Agent 标识符（如 ritsu、nova）"
        },
        "topicId": {
          "type": "string",
          "description": "话题 ID（可选，不指定则使用最新活跃话题或创建新话题）"
        },
        "title": {
          "type": "string",
          "description": "话题标题（创建新话题时使用）"
        },
        "timeout": {
          "type": "number",
          "default": 600000,
          "description": "超时时间（毫秒）"
        }
      },
      "output": {
        "status": "string",
        "answer": "string",
        "pid": "number",
        "topicId": "string",
        "title": "string",
        "isNewTopic": "boolean",
        "duration": "number"
      }
    },
    {
      "command": "interrupt",
      "description": "中断模式 - 立即关闭 OpenCode 进程，终止当前对话",
      "parameters": {
        "pid": {
          "type": "number",
          "required": true,
          "description": "要中断的进程 PID（从 chat 响应中获取）"
        }
      },
      "output": {
        "status": "string",
        "message": "string"
      }
    },
    {
      "command": "pause",
      "description": "暂停任务 - 暂停运行中的 OpenCode 任务（通过 SIGSTOP 信号）",
      "parameters": {
        "taskId": {
          "type": "string",
          "description": "任务 ID（从 taskStates 获取）"
        },
        "pid": {
          "type": "number",
          "description": "进程 PID（二选一）"
        }
      },
      "output": {
        "status": "string",
        "taskId": "string",
        "pid": "number",
        "message": "string"
      }
    },
    {
      "command": "resume",
      "description": "恢复任务 - 恢复暂停的 OpenCode 任务（通过 SIGCONT 信号）",
      "parameters": {
        "taskId": {
          "type": "string",
          "description": "任务 ID"
        },
        "pid": {
          "type": "number",
          "description": "进程 PID（二选一）"
        }
      },
      "output": {
        "status": "string",
        "taskId": "string",
        "pid": "number",
        "message": "string"
      }
    },
    {
      "command": "getTaskStatus",
      "description": "获取任务状态 - 获取指定任务的状态信息",
      "parameters": {
        "taskId": {
          "type": "string",
          "required": true,
          "description": "任务 ID"
        }
      },
      "output": {
        "status": "string",
        "task": "object"
      }
    },
    {
      "command": "listTasks",
      "description": "列出任务 - 列出所有运行中的任务",
      "parameters": {
        "agentId": {
          "type": "string",
          "description": "Agent 标识符（可选，不指定则列出所有）"
        }
      },
      "output": {
        "status": "string",
        "tasks": "array",
        "count": "number"
      }
    },
    {
      "command": "createTopic",
      "description": "创建新话题 - 为指定 Agent 创建全新的独立话题和 OpenCode 会话",
      "parameters": {
        "agentId": {
          "type": "string",
          "required": true,
          "description": "Agent 标识符"
        },
        "title": {
          "type": "string",
          "description": "话题标题（可选）"
        }
      },
      "output": {
        "status": "string",
        "topicId": "string",
        "title": "string"
      }
    },
    {
      "command": "listTopics",
      "description": "列出话题 - 列出指定 Agent 的所有话题",
      "parameters": {
        "agentId": {
          "type": "string",
          "required": true,
          "description": "Agent 标识符"
        }
      },
      "output": {
        "status": "string",
        "topics": "array"
      }
    },
    {
      "command": "getTopic",
      "description": "获取话题详情 - 获取指定话题的详细信息",
      "parameters": {
        "agentId": {
          "type": "string",
          "required": true,
          "description": "Agent 标识符"
        },
        "topicId": {
          "type": "string",
          "required": true,
          "description": "话题 ID"
        }
      },
      "output": {
        "status": "string",
        "topic": "object"
      }
    },
    {
      "command": "closeTopic",
      "description": "关闭话题 - 显式关闭指定话题，释放 OpenCode 会话",
      "parameters": {
        "agentId": {
          "type": "string",
          "required": true,
          "description": "Agent 标识符"
        },
        "topicId": {
          "type": "string",
          "required": true,
          "description": "话题 ID"
        }
      },
      "output": {
        "status": "string",
        "message": "string"
      }
    },
    {
      "command": "switchTopic",
      "description": "切换话题 - 切换到指定话题，后续 chat 将使用该话题",
      "parameters": {
        "agentId": {
          "type": "string",
          "required": true,
          "description": "Agent 标识符"
        },
        "topicId": {
          "type": "string",
          "required": true,
          "description": "话题 ID"
        }
      },
      "output": {
        "status": "string",
        "topicId": "string",
        "title": "string",
        "message": "string"
      }
    }
  ],
  "lifecycle": {
    "onUnload": "cleanup"
  },
  "safety": {
    "requiresConfirmation": true,
    "backupDirectory": ".opencode_backups",
    "maxFileSize": "10MB",
    "allowedExtensions": [".js", ".json", ".md", ".html", ".css", ".ts", ".py", ".txt", ".yaml", ".yml", ".env", ".sh", ".bat", ".ps1"]
  },
  "communication": {
    "protocol": "stdio",
    "timeout": 600000
  }
}
