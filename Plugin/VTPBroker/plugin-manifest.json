{
  "name": "VTPBroker",
  "displayName": "VCP 工具发现中间商",
  "description": "提供工具发现能力，按需返回工具分类、摘要和调用格式",
  "version": "1.0.0",
  "author": "VCP Team",
  "type": "synchronous",
  "invocationCommands": [
    {
      "command": "list_categories",
      "description": "获取所有工具分类列表",
      "inputSchema": {
        "type": "object",
        "properties": {},
        "required": []
      }
    },
    {
      "command": "list_tools",
      "description": "获取指定分类下的工具列表",
      "inputSchema": {
        "type": "object",
        "properties": {
          "category_id": {
            "type": "string",
            "description": "工具分类ID，如 'search', 'file_ops', 'code' 等"
          }
        },
        "required": ["category_id"]
      }
    },
    {
      "command": "get_tool_schema",
      "description": "获取工具的完整调用格式和参数说明",
      "inputSchema": {
        "type": "object",
        "properties": {
          "tool_id": {
            "type": "string",
            "description": "工具ID，如 'tavilysearch_tavilysearch'"
          }
        },
        "required": ["tool_id"]
      }
    }
  ]
}
