{
    "version": "1.0",
    "description": "VTPBroker 工具分类映射配置文件",
    "note": "此文件中的配置会与 category-mapper.js 中的硬编码默认值合并，文件中的配置优先",
    "categories": [
        {
            "id": "search",
            "name": "搜索工具",
            "desc": "用于在互联网或数据库中搜索信息",
            "keywords": ["搜索引擎", "搜索工具", "互联网搜索", "网络搜索", "论文搜索", "学术搜索"]
        },
        {
            "id": "image_gen",
            "name": "图像生成",
            "desc": "生成图片或编辑图像",
            "keywords": ["图像生成", "图片生成", "文生图", "图生图", "AI绘画", "AI画图", "comfyui", "stable diffusion"]
        },
        {
            "id": "video_gen",
            "name": "视频生成",
            "desc": "生成视频内容",
            "keywords": ["视频生成", "视频合成", "movie", "clip"]
        },
        {
            "id": "file_ops",
            "name": "文件操作",
